RewriteEngine On
RewriteBase /
Options +ExecCGI

# Don't rewrite admin paths
RewriteRule ^admin(/.*)?$ - [L]

# Don't rewrite existing files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Remove trailing slash
RewriteRule ^(.+)/$ $1 [R=301,L]

# Single blog pages
RewriteRule ^blog/([a-zA-Z0-9_-]+)$ blog-detail.php?slug=$1 [L,QSA]

# Single service pages
RewriteRule ^service/([a-zA-Z0-9_-]+)$ service-detail.php?slug=$1 [L,QSA]

# Named routes
RewriteRule ^home$ index.php [L]
RewriteRule ^about$ about.php [L]
RewriteRule ^services$ services.php [L]
RewriteRule ^gallery$ gallery.php [L]
RewriteRule ^blogs$ blogs.php [L]
RewriteRule ^contact$ contact.php [L]

# Remove .php extension
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]
